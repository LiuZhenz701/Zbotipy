<Window x:Class="LocalMusicPlayer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:LocalMusicPlayer.Views.Converters"
        xmlns:models="clr-namespace:LocalMusicPlayer.Models"
        xmlns:vm="clr-namespace:LocalMusicPlayer.ViewModels"
        mc:Ignorable="d"
        Title="Zbotipy"
        Icon="pack://application:,,,/ZbotipyIcon.ico"
        Height="520"
        Width="900"
        MinHeight="320"
        MinWidth="480"
        PreviewMouseLeftButtonUp="MainWindow_OnPreviewMouseLeftButtonUp"
        Closing="MainWindow_OnClosing"
        Background="#FF000000">
    <Window.Resources>
        <Style x:Key="Mdl2Icon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="#FF9CDCFE" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style x:Key="CircleIconButton" TargetType="Button">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#FF2D2D30" />
            <Setter Property="BorderBrush" Value="#FF569CD6" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Circle"
                                Width="44"
                                Height="44"
                                CornerRadius="22"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Background" Value="#FF3E3E42" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Background" Value="#FF505058" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModeIconButton" TargetType="Button" BasedOn="{StaticResource CircleIconButton}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Circle"
                                Width="40"
                                Height="40"
                                CornerRadius="20"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Background" Value="#FF3E3E42" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Background" Value="#FF505058" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#FF000000" />
            <Setter Property="BorderBrush" Value="#FF3F3F46" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FF9CDCFE" />
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#FF569CD6" />
        </Style>
        <conv:MainLyricFontSizeConverter x:Key="MainLyricFontSizeConverter" />
        <conv:MainLyricForegroundConverter x:Key="MainLyricForegroundConverter" />
        <conv:MainLyricFontWeightConverter x:Key="MainLyricFontWeightConverter" />
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A569CD6" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#33007ACC" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="12"
          TextElement.FontFamily="{StaticResource CodeEditorFontFamily}"
          TextElement.Foreground="#FF9CDCFE">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main: playlists + (tracks or lyrics) -->
        <Grid Grid.Row="0"
              Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"
                                  MinWidth="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Playlists}"
                     SelectedItem="{Binding SelectedPlaylist, Mode=TwoWay}"
                     DisplayMemberPath="Name"
                     Margin="0,0,8,0"
                     FontSize="30"
                     Foreground="#FFCE9178" />
            <!-- Songs list -->
            <ListBox x:Name="TrackList"
                     Grid.Column="1"
                     ItemsSource="{Binding Tracks}"
                     SelectedItem="{Binding SelectedTrack, Mode=TwoWay}"
                     DisplayMemberPath="DisplayName"
                     FontSize="30"
                     Foreground="#FF9CDCFE"
                     MouseDoubleClick="TrackList_OnMouseDoubleClick">
                <ListBox.Style>
                    <Style TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding MainLyricsVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
            </ListBox>
            <!-- Lyrics: synced lines, or placeholder when no .lrc -->
            <Grid Grid.Column="1">
                <ListBox x:Name="LyricsLinesList"
                         ItemsSource="{Binding MainLyricLines}"
                         SelectedIndex="{Binding CurrentLyricLineIndex, Mode=OneWay}"
                         Focusable="False"
                         IsHitTestVisible="False"
                         ScrollViewer.CanContentScroll="False"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Padding="16,24">
                    <ListBox.Style>
                        <Style TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding MainLyricsVisible}" Value="True" />
                                        <Condition Binding="{Binding HasLyricsForCurrentTrack}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel IsVirtualizing="True"
                                                    VirtualizationMode="Recycling"
                                                    ScrollUnit="Pixel" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="8,10" />
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="Transparent"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Stretch"
                                       TextOptions.TextFormattingMode="Display">
                                <TextBlock.FontSize>
                                    <MultiBinding Converter="{StaticResource MainLyricFontSizeConverter}">
                                        <Binding Path="LineIndex" />
                                        <Binding Path="DataContext.CurrentLyricLineIndex"
                                                 RelativeSource="{RelativeSource AncestorType=ListBox}" />
                                    </MultiBinding>
                                </TextBlock.FontSize>
                                <TextBlock.Foreground>
                                    <MultiBinding Converter="{StaticResource MainLyricForegroundConverter}">
                                        <Binding Path="LineIndex" />
                                        <Binding Path="DataContext.CurrentLyricLineIndex"
                                                 RelativeSource="{RelativeSource AncestorType=ListBox}" />
                                    </MultiBinding>
                                </TextBlock.Foreground>
                                <TextBlock.FontWeight>
                                    <MultiBinding Converter="{StaticResource MainLyricFontWeightConverter}">
                                        <Binding Path="LineIndex" />
                                        <Binding Path="DataContext.CurrentLyricLineIndex"
                                                 RelativeSource="{RelativeSource AncestorType=ListBox}" />
                                    </MultiBinding>
                                </TextBlock.FontWeight>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Text="{x:Static vm:MainViewModel.NoLyricsPlaceholder}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontSize="28"
                           Foreground="#FFCE9178"
                           TextOptions.TextFormattingMode="Display"
                           Panel.ZIndex="1">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding MainLyricsVisible}" Value="True" />
                                        <Condition Binding="{Binding IsAudioLoaded}" Value="True" />
                                        <Condition Binding="{Binding HasLyricsForCurrentTrack}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>

        <!-- Seek bar -->
        <Grid Grid.Row="1"
              Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0"
                    VerticalAlignment="Center"
                    Minimum="0"
                    Maximum="{Binding ProgressMaximum}"
                    Value="{Binding ProgressValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    IsMoveToPointEnabled="True"
                    PreviewMouseLeftButtonDown="PlaybackSlider_OnPreviewMouseLeftButtonDown"
                    Margin="0,0,12,0" />
            <TextBlock Grid.Column="1"
                       VerticalAlignment="Center"
                       Text="{Binding TimeDisplay}"
                       FontFamily="{StaticResource CodeEditorFontFamily}"
                       Foreground="#FFCE9178"
                       FontSize="13" />
        </Grid>

        <!-- Bottom: left/right clusters; Prev/Play/Next centered on full bar (ignores side buttons) -->
        <Grid Grid.Row="2"
              MinHeight="48">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="0,0,12,0">
                <Button Style="{StaticResource CircleIconButton}"
                        Command="{Binding LoadFolderCommand}"
                        ToolTip="Load folder"
                        Margin="0,0,8,0">
                    <TextBlock Style="{StaticResource Mdl2Icon}"
                               Text="&#xE838;"
                               FontSize="17" />
                </Button>
                <Button x:Name="FloatingLyricsButton"
                        Click="FloatingLyrics_OnClick"
                        ToolTip="Floating lyrics window"
                        Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource CircleIconButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FloatingLyricsVisible}" Value="True">
                                    <Setter Property="BorderBrush" Value="#FFCE9178" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Style="{StaticResource Mdl2Icon}"
                               Text="&#xE8A7;"
                               FontSize="17" />
                </Button>
                <Button Command="{Binding ToggleDiscordPresenceCommand}"
                        Margin="0,0,8,0"
                        ToolTip="Discord rich presence">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource CircleIconButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DiscordRichPresenceEnabled}" Value="True">
                                    <Setter Property="BorderBrush" Value="#FFCE9178" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Image Width="28"
                           Height="28"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Source>
                            <BitmapImage UriSource="pack://application:,,,/Discord_Logo.png" />
                        </Image.Source>
                    </Image>
                </Button>
                <Button Command="{Binding ToggleMinimizeToTrayCommand}"
                        ToolTip="Minimize to notification area">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource CircleIconButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MinimizeToTray}" Value="True">
                                    <Setter Property="BorderBrush" Value="#FFCE9178" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock FontFamily="{StaticResource CodeEditorFontFamily}"
                               Text="-"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#FF9CDCFE"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Command="{Binding SetPlaybackModeNormalCommand}"
                        ToolTip="Normal (stop after last track)"
                        Margin="0,0,6,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ModeIconButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentPlaybackMode}" Value="{x:Static models:PlaybackMode.Normal}">
                                    <Setter Property="BorderBrush" Value="#FFCE9178" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Opacity="{Binding PlaybackModeNormalOpacity}"
                               Style="{StaticResource Mdl2Icon}"
                               Text="&#xE1F2;"
                               FontSize="15" />
                </Button>
                <Button Command="{Binding SetPlaybackModeRepeatAllCommand}"
                        ToolTip="Repeat all"
                        Margin="0,0,6,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ModeIconButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentPlaybackMode}" Value="{x:Static models:PlaybackMode.RepeatAll}">
                                    <Setter Property="BorderBrush" Value="#FFCE9178" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Opacity="{Binding PlaybackModeRepeatAllOpacity}"
                               Style="{StaticResource Mdl2Icon}"
                               Text="&#xE8EE;"
                               FontSize="15" />
                </Button>
                <Button Command="{Binding SetPlaybackModeRepeatOneCommand}"
                        ToolTip="Repeat one"
                        Margin="0,0,6,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ModeIconButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentPlaybackMode}" Value="{x:Static models:PlaybackMode.RepeatOne}">
                                    <Setter Property="BorderBrush" Value="#FFCE9178" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Opacity="{Binding PlaybackModeRepeatOneOpacity}"
                               Style="{StaticResource Mdl2Icon}"
                               Text="&#xE8ED;"
                               FontSize="15" />
                </Button>
                <Button Command="{Binding SetPlaybackModeShuffleCommand}"
                        ToolTip="Shuffle"
                        Margin="0,0,12,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ModeIconButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentPlaybackMode}" Value="{x:Static models:PlaybackMode.Shuffle}">
                                    <Setter Property="BorderBrush" Value="#FFCE9178" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Opacity="{Binding PlaybackModeShuffleOpacity}"
                               Style="{StaticResource Mdl2Icon}"
                               Text="&#xE8B1;"
                               FontSize="15" />
                </Button>
                <Button Command="{Binding ToggleMainLyricsCommand}"
                        ToolTip="Show or hide lyrics in main area">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource CircleIconButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MainLyricsVisible}" Value="True">
                                    <Setter Property="BorderBrush" Value="#FFCE9178" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Style="{StaticResource Mdl2Icon}"
                               Text="&#xE8D3;"
                               FontSize="18" />
                </Button>
            </StackPanel>

            <!-- Only these three use horizontal center of the entire bottom bar -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Panel.ZIndex="1">
                <Button Style="{StaticResource CircleIconButton}"
                        Command="{Binding PreviousCommand}"
                        ToolTip="Previous"
                        Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource Mdl2Icon}"
                               Text="&#xE100;"
                               FontSize="18" />
                </Button>
                <Button Style="{StaticResource CircleIconButton}"
                        Command="{Binding PlayPauseCommand}"
                        ToolTip="Play / Pause"
                        Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource Mdl2Icon}"
                               Text="{Binding PlayPauseIconGlyph}"
                               FontSize="20" />
                </Button>
                <Button Style="{StaticResource CircleIconButton}"
                        Command="{Binding NextCommand}"
                        ToolTip="Next">
                    <TextBlock Style="{StaticResource Mdl2Icon}"
                               Text="&#xE101;"
                               FontSize="18" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
