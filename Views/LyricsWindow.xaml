<Window x:Class="LocalMusicPlayer.Views.LyricsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lyrics"
        Width="800"
        Height="150"
        MinWidth="800"
        MinHeight="150"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style x:Key="TransportIconText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="#FF9CDCFE" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid Margin="14,0,14,12">
        <!-- Lyrics + toolbar row; transport + lock share BottomToolbarChromePanel (hidden until cursor over window) -->
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    MaxWidth="720"
                    Margin="0">
            <StackPanel Cursor="SizeAll"
                        TextOptions.TextFormattingMode="Display"
                        MouseLeftButtonDown="LyricText_OnMouseLeftButtonDown">
                <TextBlock x:Name="CurrentLyricText"
                           Text="{Binding CurrentLyric}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           FontFamily="{StaticResource CodeEditorFontFamily}"
                           Foreground="#FFCE9178"
                           FontSize="28"
                           FontWeight="SemiBold"
                           MinHeight="30"
                           TextOptions.TextFormattingMode="Display" />
                <TextBlock x:Name="NextLyricText"
                           Text="{Binding NextLyric}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           FontFamily="{StaticResource CodeEditorFontFamily}"
                           Foreground="#FF9CDCFE"
                           FontSize="24"
                           Margin="0,4,0,0"
                           MinHeight="24"
                           TextOptions.TextFormattingMode="Display" />
            </StackPanel>

            <Grid x:Name="ToolbarRow"
                  MinHeight="32"
                  Margin="0,8,0,0"
                  Background="Transparent"
                  Cursor="SizeAll"
                  MouseLeftButtonDown="ToolbarRow_OnMouseLeftButtonDown">
                <StackPanel x:Name="BottomToolbarChromePanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <Button x:Name="PrevButton"
                            Padding="10,4"
                            MinWidth="40"
                            Margin="0,0,10,0"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip="Previous track"
                            Command="{Binding PreviousCommand}">
                        <TextBlock Style="{StaticResource TransportIconText}"
                                   Text="&#xE100;"
                                   TextOptions.TextFormattingMode="Display" />
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    </Button>
                    <Button x:Name="PlayPauseButton"
                            Padding="10,4"
                            MinWidth="40"
                            Margin="0,0,10,0"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip="Play or pause"
                            Command="{Binding PlayPauseCommand}">
                        <TextBlock Style="{StaticResource TransportIconText}"
                                   Text="{Binding PlayPauseIconGlyph}"
                                   TextOptions.TextFormattingMode="Display" />
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    </Button>
                    <Button x:Name="NextButton"
                            Padding="10,4"
                            MinWidth="40"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip="Next track"
                            Command="{Binding NextCommand}">
                        <TextBlock Style="{StaticResource TransportIconText}"
                                   Text="&#xE101;"
                                   TextOptions.TextFormattingMode="Display" />
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    </Button>
                    <ToggleButton x:Name="ClickThroughToggle"
                                  Margin="14,0,0,0"
                                  Padding="8,2"
                                  FontSize="15"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Checked="ClickThroughToggle_OnChecked"
                                  Unchecked="ClickThroughToggle_OnUnchecked">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Padding="{TemplateBinding Padding}"
                                                    Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Top-right close; must stay hit-testable when click-through is on -->
        <Border x:Name="CloseHitArea"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="Transparent"
                Padding="6"
                Margin="-6,0,-10,-6"
                Cursor="Hand"
                Visibility="Collapsed">
            <Button x:Name="CloseLyricsButton"
                    Content="✕"
                    Padding="10,4"
                    MinWidth="36"
                    MinHeight="28"
                    FontFamily="{StaticResource CodeEditorFontFamily}"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="#FFCE9178"
                    Background="Transparent"
                    BorderThickness="0"
                    ToolTip="Hide"
                    Click="CloseButton_OnClick">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Border>
    </Grid>
</Window>
