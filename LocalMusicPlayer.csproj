<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <DefaultItemExcludes>$(DefaultItemExcludes);$(MSBuildProjectDirectory)/obj_lyrics/**</DefaultItemExcludes>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>Zbotipy</AssemblyName>
    <RootNamespace>LocalMusicPlayer</RootNamespace>
    <ApplicationIcon>ZbotipyIcon.ico</ApplicationIcon>
    <AssemblyTitle>Zbotipy</AssemblyTitle>
    <Product>Zbotipy</Product>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="ZbotipyIcon.ico" />
    <Resource Include="Discord_Logo.png" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="DiscordRichPresence" Version="1.6.1.70" />
    <PackageReference Include="NAudio" Version="2.3.0" />
    <PackageReference Include="TagLibSharp" Version="2.3.0" />
  </ItemGroup>

</Project>
